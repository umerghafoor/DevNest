# Copy this file to `.env.local` and fill in your values.
# Variables prefixed with VITE_ are exposed to the frontend.

# Default GitHub OAuth Client ID baked into the build. Register an OAuth App
# at https://github.com/settings/developers, enable "Device Flow", and paste
# the Client ID below. Users can still override this from Settings → Integrations.
VITE_GITHUB_CLIENT_ID=
